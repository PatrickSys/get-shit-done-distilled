#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');
const os = require('os');

const args = process.argv.slice(2);
const command = args[0];

function checkBranch() {
  try {
    const branch = execSync('git branch --show-current', { stdio: 'pipe' }).toString().trim();
    if (branch === 'main' || branch === 'master') {
      console.error('\x1b[31mError: You are on the main/master branch.\x1b[0m');
      console.error('Governance: Please create a feature branch before starting work.');
      console.error('  git checkout -b feature/your-goal');
      process.exit(1);
    }
  } catch (e) {
    // If not a git repo, warn but proceed? Or strict?
    console.warn('\x1b[33mWarning: Not a git repository or git error.\x1b[0m');
  }
}

function init() {
  // 1. Create .planning directory (private scratchpad)
  const planningDir = '.planning';
  if (!fs.existsSync(planningDir)) {
    fs.mkdirSync(planningDir);
  }

  // 2. Create gsdd.json (versioned config)
  const configPath = 'gsdd.json';
  if (!fs.existsSync(configPath)) {
    const config = {
      version: "1.0",
      commit_docs: false,
      workflow: {
        research: true,
        plan_check: true,
        verifier: true
      }
    };
    fs.writeFileSync(configPath, JSON.stringify(config, null, 2));
    console.log('\x1b[32mInitialized GSD Distilled config at gsdd.json\x1b[0m');
    console.log('Governance: commit_docs set to false (no planning artifacts in repo).');
  } else {
    console.log('Config already exists at gsdd.json');
  }

  // 3. Update .gitignore (ensure .planning/ is ignored)
  if (fs.existsSync('.gitignore')) {
    const gitignore = fs.readFileSync('.gitignore', 'utf8');
    if (!gitignore.includes('.planning/')) {
      fs.appendFileSync('.gitignore', '\n.planning/\n');
      console.log('Added .planning/ to .gitignore');
    }
  } else {
    fs.writeFileSync('.gitignore', '.planning/\n');
    console.log('Created .gitignore with .planning/');
  }
}

function getWorkflowPath(workflow) {
    // Heuristic to find where GSD is installed
    // Priority: Local .claude -> Global ~/.claude -> Default to global path string

    if (fs.existsSync('.claude/get-shit-done')) {
        return `@.claude/get-shit-done/workflows/distilled/${workflow}`;
    }
    // Default to global
    return `@~/.claude/get-shit-done/workflows/distilled/${workflow}`;
}

function printInstruction(prompt) {
    console.log('\n\x1b[36m=== Copy and paste this into your AI agent ===\x1b[0m\n');
    console.log(prompt);
    console.log('\n\x1b[36m==============================================\x1b[0m\n');
}

function spec(args) {
    checkBranch();
    init(); // Ensure config exists

    // Parse args
    const isClaude = args.includes('--claude');
    const goalArgs = args.filter(a => a !== '--claude');
    const goal = goalArgs.join(' ');

    if (!goal) {
        console.error('Error: Please provide a goal.');
        console.error('Usage: gsdd spec "Add user login" [--claude]');
        process.exit(1);
    }

    if (isClaude) {
        const workflow = getWorkflowPath('spec.md');
        const prompt = `Execute workflow ${workflow}\n\nGOAL: ${goal}`;
        printInstruction(prompt);
    } else {
        // Agent-agnostic work order
        const prompt = `
Please create a specification for the following goal:
"${goal}"

Instructions:
1. (Optional) Research the goal if needed to understand requirements and tech stack.
2. Create a file named \`.planning/SPEC.md\`.
3. In \`.planning/SPEC.md\`, create a checklist of atomic tasks to achieve the goal.
4. Include a "Must Haves" section listing verification criteria.
5. Format tasks as Markdown checkboxes (e.g., - [ ] Task description).
`;
        printInstruction(prompt);
    }
}

function execute(args) {
    checkBranch();
    // Check if SPEC.md exists
    if (!fs.existsSync('.planning/SPEC.md')) {
        console.error('Error: .planning/SPEC.md not found. Run "gsdd spec <goal>" first.');
        process.exit(1);
    }

    const isClaude = args.includes('--claude');

    if (isClaude) {
        const workflow = getWorkflowPath('execute.md');
        const prompt = `Execute workflow ${workflow}`;
        printInstruction(prompt);
    } else {
        // Agent-agnostic work order
        const prompt = `
Please execute the plan in \`.planning/SPEC.md\`.

Instructions:
1. Read \`.planning/SPEC.md\`.
2. Execute each task in the checklist.
3. Mark tasks as completed in \`.planning/SPEC.md\` (change [ ] to [x]) as you finish them.
4. Commit each task atomically (one commit per task).
5. Create a file \`.planning/SUMMARY.md\` summarizing what was done.
`;
        printInstruction(prompt);
    }
}

function verify(args) {
    checkBranch();

    const isClaude = args.includes('--claude');

    if (isClaude) {
        const workflow = getWorkflowPath('verify.md');
        const prompt = `Execute workflow ${workflow}`;
        printInstruction(prompt);
    } else {
        // Agent-agnostic work order
        const prompt = `
Please verify the implementation against \`.planning/SPEC.md\`.

Instructions:
1. Read the "Must Haves" section in \`.planning/SPEC.md\`.
2. Verify that each requirement is met.
3. Run any relevant automated tests.
4. Create a report in \`.planning/VERIFICATION.md\`.
`;
        printInstruction(prompt);
    }
}

function doCommand(args) {
    checkBranch();
    init();

    const isClaude = args.includes('--claude');
    const goalArgs = args.filter(a => a !== '--claude');
    const goal = goalArgs.join(' ');

    if (!goal) {
        console.error('Error: Please provide a goal.');
        console.error('Usage: gsdd do "Add user login" [--claude]');
        process.exit(1);
    }

    if (isClaude) {
        // Claude-specific chained instructions
        const specWf = getWorkflowPath('spec.md');
        const execWf = getWorkflowPath('execute.md');
        const verifyWf = getWorkflowPath('verify.md');

        const prompt = `
Goal: ${goal}

1. Execute workflow ${specWf} with GOAL: ${goal}
2. Once complete, execute workflow ${execWf}
3. Once complete, execute workflow ${verifyWf}
`;
        printInstruction(prompt);
    } else {
        // Agent-agnostic happy path
        const prompt = `
Goal: "${goal}"

Please complete this goal using the following process:

1. **Spec**: Create \`.planning/SPEC.md\` with a checklist of tasks and verification criteria ("Must Haves").
2. **Execute**: Implement the tasks, marking them done in SPEC.md and committing atomically. create \`.planning/SUMMARY.md\`.
3. **Verify**: Check the implementation against criteria and write \`.planning/VERIFICATION.md\`.
`;
        printInstruction(prompt);
    }
}

function help() {
    console.log(`
GSD Distilled (gsdd) - A governed, simplified workflow for AI agents.

Usage:
  gsdd <command> [options]

Commands:
  init      Initialize project (config, gitignore).
  spec      Generate instructions to Spec/Plan a goal.
  execute   Generate instructions to Execute the plan.
  verify    Generate instructions to Verify the work.
  do        Generate instructions to do it all in one go.
  help      Show this help.

Options:
  --claude  Output Claude-specific workflow instructions (uses GSD engine).

Workflow:
  1. gsdd spec "My Goal"  -> prompts agent to Research & Plan
  2. gsdd execute         -> prompts agent to Build
  3. gsdd verify          -> prompts agent to Verify
`);
}

switch (command) {
    case 'init':
        init();
        break;
    case 'spec':
        spec(args.slice(1));
        break;
    case 'execute':
        execute(args.slice(1));
        break;
    case 'verify':
        verify(args.slice(1));
        break;
    case 'do':
        doCommand(args.slice(1));
        break;
    case 'help':
    case '--help':
    case '-h':
    default:
        help();
        break;
}
